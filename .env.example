# Firebase Web SDK (public, used in browser)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=
NEXT_PUBLIC_DEFAULT_WORKSPACE_ID=default
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Firebase Admin SDK (private, server-only)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
# Alternative for local scripts: either raw service-account JSON or a path to the JSON file.
FIREBASE_SERVICE_ACCOUNT_JSON=
# Alternative supported by Firebase Admin ADC when FIREBASE_PROJECT_ID is set.
GOOGLE_APPLICATION_CREDENTIALS=
# Optional server override. Defaults to NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET when empty.
FIREBASE_STORAGE_BUCKET=

# Dev note:
# - Use your provided project values only in .env.local for local development.
# - In Firebase App Hosting (prod), configure these as environment variables/secrets in the platform.

# Workspace invites
INVITE_BASE_URL=http://localhost:3000
RESEND_API_KEY=
INVITE_EMAIL_FROM=TeamKnowledge <onboarding@resend.dev>

# Demo seed
DEMO_USER_PASSWORD=TeamKnowledge@2024

# Security (development only — never enable in production)
ALLOW_INSECURE_DEV_AUTH=false
