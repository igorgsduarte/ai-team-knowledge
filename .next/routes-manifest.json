{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "priority": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/api/workspaces/[workspaceId]/agents",
      "regex": "^/api/workspaces/([^/]+?)/agents(?:/)?$",
      "routeKeys": {
        "nxtPworkspaceId": "nxtPworkspaceId"
      },
      "namedRegex": "^/api/workspaces/(?<nxtPworkspaceId>[^/]+?)/agents(?:/)?$"
    },
    {
      "page": "/knowledge/[id]",
      "regex": "^/knowledge/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/knowledge/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/skills/[id]",
      "regex": "^/skills/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/skills/(?<nxtPid>[^/]+?)(?:/)?$"
    }
  ],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_global-error",
      "regex": "^/_global\\-error(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_global\\-error(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/api/auth/sign-in",
      "regex": "^/api/auth/sign\\-in(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/auth/sign\\-in(?:/)?$"
    },
    {
      "page": "/api/auth/sign-out",
      "regex": "^/api/auth/sign\\-out(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/auth/sign\\-out(?:/)?$"
    },
    {
      "page": "/api/auth/sign-up",
      "regex": "^/api/auth/sign\\-up(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/auth/sign\\-up(?:/)?$"
    },
    {
      "page": "/api/mcp/connect",
      "regex": "^/api/mcp/connect(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/mcp/connect(?:/)?$"
    },
    {
      "page": "/api/mcp/status",
      "regex": "^/api/mcp/status(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/mcp/status(?:/)?$"
    },
    {
      "page": "/board",
      "regex": "^/board(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/board(?:/)?$"
    },
    {
      "page": "/dashboard",
      "regex": "^/dashboard(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/dashboard(?:/)?$"
    },
    {
      "page": "/knowledge",
      "regex": "^/knowledge(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/knowledge(?:/)?$"
    },
    {
      "page": "/profile",
      "regex": "^/profile(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/profile(?:/)?$"
    },
    {
      "page": "/sign-in",
      "regex": "^/sign\\-in(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/sign\\-in(?:/)?$"
    },
    {
      "page": "/sign-up",
      "regex": "^/sign\\-up(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/sign\\-up(?:/)?$"
    },
    {
      "page": "/skills",
      "regex": "^/skills(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/skills(?:/)?$"
    },
    {
      "page": "/team",
      "regex": "^/team(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/team(?:/)?$"
    }
  ],
  "dataRoutes": [],
  "rsc": {
    "header": "rsc",
    "varyHeader": "rsc, next-router-state-tree, next-router-prefetch, next-router-segment-prefetch",
    "prefetchHeader": "next-router-prefetch",
    "didPostponeHeader": "x-nextjs-postponed",
    "contentTypeHeader": "text/x-component",
    "suffix": ".rsc",
    "prefetchSuffix": ".prefetch.rsc",
    "prefetchSegmentHeader": "next-router-segment-prefetch",
    "prefetchSegmentSuffix": ".segment.rsc",
    "prefetchSegmentDirSuffix": ".segments",
    "clientParamParsing": false,
    "dynamicRSCPrerender": false
  },
  "rewriteHeaders": {
    "pathHeader": "x-nextjs-rewritten-path",
    "queryHeader": "x-nextjs-rewritten-query"
  }
}